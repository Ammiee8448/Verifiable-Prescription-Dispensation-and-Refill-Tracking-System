## Example Contract Stubs

### contracts/prescription-registry.clar
```clarity
(define-data-var prescription-counter uint u0)

(define-map prescriptions
  {id: uint}
  {patient: principal, doctor: principal, drug: (string-ascii 50), dosage: (string-ascii 50), refills: uint, issuedAt: uint, validUntil: uint, active: bool})

(define-map authorized-doctors
  {doctor: principal}
  {verified: bool})

;; Add doctor
(define-public (authorize-doctor (doc principal))
  (begin
    (map-set authorized-doctors {doctor: doc} {verified: true})
    (ok true)))

;; Issue prescription
(define-public (issue-prescription (patient principal) (drug (string-ascii 50)) (dosage (string-ascii 50)) (refills uint) (validUntil uint))
  (let ((id (+ (var-get prescription-counter) u1)))
    (begin
      (var-set prescription-counter id)
      (map-set prescriptions {id: id}
        {patient: patient, doctor: tx-sender, drug: drug, dosage: dosage, refills: refills, issuedAt: block-height, validUntil: validUntil, active: true})
      (ok id)))))
